{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["vitest/globals", "node"],
    "noEmit": false,
    "esModuleInterop": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "src/**/*.test.*",
    "src/**/*.spec.*",
    "src/vite-env.d.ts"
  ],
  "exclude": ["node_modules", "dist", "build"]
}
