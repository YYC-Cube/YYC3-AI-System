  "scripts": {
    "dev": "vite --port 3156",
    "build": "vite build",
    "preview": "vite preview --port 3156",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:performance": "vitest run performance-monitor-service.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "benchmark": "pnpm run test:e2e e2e/performance-benchmark.test.ts",
    "report:bundle": "node --loader tsx scripts/generate-bundle-analysis-report.ts",
    "report:performance": "node --loader tsx scripts/generate-performance-benchmark-report.ts",
    "report:e2e": "node --loader tsx scripts/generate-e2e-test-report.ts",
    "ci": "npm run lint && npm run format:check && npm run typecheck && npm run test:run"
  },
